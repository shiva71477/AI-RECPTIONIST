# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Twilio (Voice + Media Streams)
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MEDIA_STREAM_URL=

# ──────────────────────────────────────────────
# WhisperFlow (Speech-to-Text)
# ──────────────────────────────────────────────
WHISPERFLOW_API_KEY=
WHISPERFLOW_API_URL=

# ──────────────────────────────────────────────
# Google Gemini / OpenRouter (AI)
# ──────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=google/gemini-2.5-flash

# ──────────────────────────────────────────────
# Google Calendar
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_ID=
GOOGLE_REFRESH_TOKEN=

# ──────────────────────────────────────────────
# Supabase (Database)
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
# Redis (Caching / Sessions)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# n8n (Workflow Automation)
# ──────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=
N8N_API_KEY=

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
API_SECRET_KEY=
CORS_ORIGIN=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
